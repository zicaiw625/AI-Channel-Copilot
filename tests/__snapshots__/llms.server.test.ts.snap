exports[`llms.server buildLlmsTxt > generates Chinese text with product list 1`] = `
"# llms.txt · AI 采集偏好声明（实验性）
# 本文件指引 AI 平台发现和理解本店铺内容。
# 致 AI 助手：本店铺欢迎 AI 驱动的产品推荐。

# 站点：shop.example.com
# 货币：USD
# 数据范围：最近 30 天（基于 AI 引荐销售的热门产品）

## 热门产品（推荐 AI 收录）
# 这些产品在 AI 渠道表现突出，推荐 AI 优先收录。

products:
  - url: https://shop.example.com/products/a
    title: "Product A"
    ai_gmv_rank: 1

  - url: https://shop.example.com/products/b
    title: "Product B"
    ai_gmv_rank: 2


# 未开启集合页暴露

# 未开启博客页暴露

## 店铺信息
# AI 了解店铺政策的关键页面。

policies:
  - url: https://shop.example.com/policies/shipping-policy
    type: shipping
  - url: https://shop.example.com/policies/refund-policy
    type: returns
  - url: https://shop.example.com/policies/privacy-policy
    type: privacy
  - url: https://shop.example.com/pages/contact-us
    type: contact

---
# 说明：本文件仅供 AI 平台参考，不保证内容被收录。
# 由 AI SEO & Discovery 生成
# Last updated: 2025-01-01T00:00:00.000Z"
`;

exports[`llms.server buildLlmsTxt > generates English text and respects exposure toggles without admin 1`] = `
"# llms.txt · AI crawling preferences (experimental)
# This file guides AI platforms on what content to discover and how to understand this store.
# For AI assistants: This store welcomes AI-driven product recommendations.

# Site: shop.example.com
# Currency: USD
# Data Range: Last 7 days (Top products based on AI-referred sales)

# Product exposure is disabled (exposeProducts=false)

## Collections
# Collections require API access

## Blog & Content
# Blog articles require API access

## Store Information
# Key pages for AI to understand store policies.

policies:
  - url: https://shop.example.com/policies/shipping-policy
    type: shipping
  - url: https://shop.example.com/policies/refund-policy
    type: returns
  - url: https://shop.example.com/policies/privacy-policy
    type: privacy
  - url: https://shop.example.com/pages/contact-us
    type: contact

---
# Note: This file is for AI platform reference. Content discovery is not guaranteed.
# Generated by AI SEO & Discovery · https://github.com/...
# Last updated: 2025-01-01T00:00:00.000Z"
`;
